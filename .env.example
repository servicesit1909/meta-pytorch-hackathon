# ------------------------------------------------------------------------------
# OpSentrix SRE Harness -- Environment Configuration
# ------------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ------------------------------------------------------------------------------

# -- Server --------------------------------------------------------------------
OPSENTRIX_HOST=0.0.0.0
OPSENTRIX_PORT=7860
OPSENTRIX_WORKERS=1
OPSENTRIX_RELOAD=false
OPSENTRIX_DEFAULT_TASK=latency_triage
LOG_LEVEL=INFO

# -- CORS ----------------------------------------------------------------------
# Comma-separated list of allowed origins. Use * for development.
CORS_ORIGINS=*

# -- Inference Agent -----------------------------------------------------------
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini
HF_TOKEN=hf_your_token_here
OPSENTRIX_SERVER_URL=http://localhost:7860
MAX_RETRIES=3
REQUEST_TIMEOUT=60
MAX_STEPS_PER_EPISODE=20
MAX_RUNTIME_SECONDS=1140
